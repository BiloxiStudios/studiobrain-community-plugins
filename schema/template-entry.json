{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/BiloxiStudios/studiobrain-community-plugins/blob/main/schema/template-entry.json",
  "title": "StudioBrain Community Template Entry",
  "description": "Schema for a template, rule, or layout entry in the community registry",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "description",
    "author",
    "content_type",
    "template_category",
    "repo_url",
    "file_url",
    "platforms",
    "tags",
    "min_version",
    "license"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique identifier. Use author-name format.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 3,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name.",
      "minLength": 1,
      "maxLength": 100
    },
    "version": {
      "type": "string",
      "description": "Semver version of the content.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "description": {
      "type": "string",
      "description": "Short description. Max 200 characters.",
      "minLength": 10,
      "maxLength": 200
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "content_type": {
      "type": "string",
      "description": "What kind of content this is.",
      "enum": ["template", "rule", "layout"]
    },
    "template_category": {
      "type": "string",
      "description": "Template rendering category. Only meaningful for content_type=template.",
      "enum": ["entity", "document", "map", "rule", "skill"]
    },
    "repo_url": {
      "type": "string",
      "description": "URL to the source repository.",
      "format": "uri",
      "pattern": "^https://"
    },
    "file_url": {
      "type": "string",
      "description": "Direct URL to the .md file (templates/rules) or .json file (layouts). May be empty if bundled in repo.",
      "oneOf": [
        { "const": "" },
        { "format": "uri", "pattern": "^https://" }
      ]
    },
    "platforms": {
      "type": "array",
      "description": "StudioBrain editions this content works with.",
      "items": {
        "type": "string",
        "enum": ["core", "desktop", "cloud"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
        "maxLength": 32
      },
      "maxItems": 5,
      "uniqueItems": true
    },
    "min_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    }
  }
}
